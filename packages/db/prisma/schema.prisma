// bonds Prisma schema — フェーズ1 (人物DD MVP)。
// 人物DD側は公開情報主体のため原則暗号化なし (DESIGN-HANDOVER.md §4.1)。
// フェーズ2 で contacts 系 (暗号化) を追加する。
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 管理者が変更するアプリ設定 (例: person_eval_model)。cares app_config を踏襲。
model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_config")
}

/// DB 駆動プロンプト (key + version、管理画面編集)。vm/cares の prompts を踏襲。
model Prompt {
  id        String   @id @default(uuid())
  key       String
  version   Int      @default(1)
  model     String?
  body      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([key, version])
  @@map("prompts")
}

/// 人物DD の評価対象 (公人)。vm-suite companies の人物版。
model DdSubject {
  id           String   @id @default(uuid())
  slug         String   @unique
  name         String
  nameEn       String?  @map("name_en")
  nameKana     String?  @map("name_kana")
  subjectType  String   @default("other") @map("subject_type") // politician / executive / other
  affiliations Json?
  country      String?
  profileHint  String?  @map("profile_hint") // 同姓同名の特定メモ (ユーザーが選んだ候補の簡単なプロフィール)
  state        String   @default("active") // active / archived
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  dueDiligences PersonDueDiligence[]

  @@map("dd_subjects")
}

/// 人物DD の実行 1 回 (モジュール単位)。vm-suite due_diligences の複製。
model PersonDueDiligence {
  id              String    @id @default(uuid())
  subjectId       String    @map("subject_id")
  subject         DdSubject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  ddType          String    @map("dd_type") // consciousness_7d / social_value_creation
  promptKey       String?   @map("prompt_key")
  promptVersion   Int?      @map("prompt_version")
  model           String
  provider        String    @default("anthropic")
  referenceDate   DateTime? @map("reference_date")
  inputJson       Json?     @map("input_json")
  outputText      String?   @map("output_text")
  outputJson      Json?     @map("output_json")
  scores          Json?
  moduleScore     Float?    @map("module_score")
  confidenceScore Float?    @map("confidence_score")
  status          String    @default("pending") // pending / running / completed / invalid_output / failed
  errorDetail     String?   @map("error_detail")
  inputTokens     Int       @default(0) @map("input_tokens")
  outputTokens    Int       @default(0) @map("output_tokens")
  durationMs      Int?      @map("duration_ms")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  steps PersonDdStep[]

  @@index([subjectId, ddType, createdAt])
  @@map("person_due_diligences")
}

/// 実行内の 1 ステップ。vm-suite due_diligence_steps の複製。
/// フェーズ1 は search (知識ベースのため skipped) → evaluate の 2 ステップ。
model PersonDdStep {
  id          String             @id @default(uuid())
  personDdId  String             @map("person_dd_id")
  personDd    PersonDueDiligence @relation(fields: [personDdId], references: [id], onDelete: Cascade)
  stepKey     String             @map("step_key")
  stepType    String             @map("step_type") // search / evaluate
  promptKey   String?            @map("prompt_key")
  model       String?
  inputJson   Json?              @map("input_json")
  outputJson  Json?              @map("output_json")
  outputText  String?            @map("output_text")
  status      String             @default("pending") // pending / running / completed / skipped / failed
  errorDetail String?            @map("error_detail")
  startedAt   DateTime?          @map("started_at")
  finishedAt  DateTime?          @map("finished_at")
  createdAt   DateTime           @default(now()) @map("created_at")

  @@index([personDdId])
  @@map("person_dd_steps")
}

/// AI 利用記録。月次円建てキャップ (BR-20 相当) の集計元。
model AiUsageLog {
  id           String   @id @default(uuid())
  ownerUid     String?  @map("owner_uid") // どの利用者の消費か (月次上限を利用者ごとに効かせる)。旧行は null
  provider     String
  model        String
  purpose      String // person_dd_consciousness_7d / person_dd_social_value_creation など
  inputTokens  Int      @map("input_tokens")
  outputTokens Int      @map("output_tokens")
  costJpy      Float    @map("cost_jpy")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([purpose, createdAt])
  @@index([ownerUid, createdAt])
  @@map("ai_usage_logs")
}

/// 取り込みジョブ。ファイル/貼り付けをサーバ側に預けて処理する = ページを離れても続く。
/// payload は本文 (テキスト or base64 バイト列) で PII を含むため暗号化する。
model ImportJob {
  id                String   @id @default(uuid())
  ownerUid          String   @map("owner_uid")
  kind              String // "text" | "file"
  filename          String?
  payload           String // 暗号化: テキスト本文 or base64(バイト列)
  locale            String   @default("ja")
  eventName         String?  @map("event_name") // どこで出会ったか (パーティ・イベント取込)
  eventDate         String?  @map("event_date") // いつ出会ったか (YYYY-MM-DD)
  status            String   @default("queued") // queued / processing / done / error
  attempts          Int      @default(0) // 処理を試みた回数 (停止した processing の回収と打ち切りに使う)
  imported          Int      @default(0)
  enriched          Int      @default(0)
  interactionsAdded Int      @default(0) @map("interactions_added")
  skipped           Int      @default(0)
  detail            String? // 結果/エラーの短い説明 (名前などの PII は入れない)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([ownerUid, status])
  @@index([ownerUid, createdAt])
  @@map("import_jobs")
}

/// 連絡先 (ユーザーの人脈)。PII の塊 = ENCRYPTED_FIELDS で項目暗号化 (DESIGN-HANDOVER.md §4.1)。
/// distance: 1(毎日)〜5(遠い)。1〜3 が接触間隔の監視対象 (lms 移植)。
model Contact {
  id              String    @id @default(uuid())
  ownerUid        String    @default("owner") @map("owner_uid") // フェーズ5 の認証導入までは単一オーナー
  name            String
  furigana        String?
  distance        Int       @default(4)
  relationship    String    @default("other") // family / friend / work / mentor / other など
  birthday        DateTime?
  anniversary     DateTime? // 記念日 (結婚記念日・出会った日など)。贈り物リマインドに使う
  phone           String? // 暗号化
  email           String? // 暗号化
  address         String? // 暗号化
  company         String?
  title           String?
  sns             String? // 暗号化 (JSON 文字列)
  snsCandidates   String?   @map("sns_candidates") // 暗号化: 本人と思われる SNS の候補 (未確認)。承認で sns へ、削除で消える
  personalProfile String?   @map("personal_profile") // 暗号化: 健康・家族友人・悩み・課題・夢など
  socialPosition  String?   @map("social_position") // 暗号化: 社会的位置づけ
  valuesProfile   String?   @map("values_profile") // 暗号化: 価値観・目標/目的
  notes           String? // 暗号化
  profileDigest   String?   @map("profile_digest") // 暗号化: 記録から自動でまとまる相手ノート (見立て)
  profileDigestAt DateTime? @map("profile_digest_at") // 見立ての最終更新 (これより新しい記録があれば再生成対象)
  profileFacets   String?   @map("profile_facets") // 暗号化: 記録から整理した論点 (連絡先/状況/スキル/悩み/家族/仕事/健康/価値観/目標 等) の JSON
  profileFacetsAt DateTime? @map("profile_facets_at") // 論点の最終更新
  goal            String? // 暗号化: 関係の目標 (用途・目標距離感・ねらい・設定時距離) の JSON。恋活婚活等の要配慮情報を含みうる
  source          String    @default("manual") // manual / csv / vcard / sns / eight / nengajo
  sourceHits      Int       @default(1) @map("source_hits") // 取込・名寄せで同じ方に行き当たった延べ回数 (くり返し登場 = 重要の弱いシグナル)
  focusPreference String?   @map("focus_preference") // pinned / excluded — 優先リストへのユーザーの意思 (null = 自動判定)
  state           String    @default("active") // active / archived (ソフト削除)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  interactions ContactInteraction[]
  gifts        ContactGift[]
  exchanges    Exchange[]
  shares       ResourceShare[]
  externalRefs ContactExternalRef[]
  threads      MessageThread[]

  @@index([ownerUid, state])
  @@map("contacts")
}

/// やり取り台帳 (Gift を一般化)。贈与だけでなく、貢献・貸し借り・取引・約束を1件ずつ記録する。
/// title / notes は内容 (PII) なのでアプリ層暗号化。kind/status/value は集計・督促に使うので平文。
/// prev_hash / hash は任意の改ざん検知チェーン (不変の中核だけをハッシュ。ブロックチェーンは使わない)。
model Exchange {
  id         String    @id @default(uuid())
  ownerUid   String    @map("owner_uid")
  contactId  String    @map("contact_id")
  contact    Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  kind       String    @default("gift") // gift / favor(貢献) / loan(貸し借り) / deal(取引) / promise(約束) / other
  direction  String    @default("outbound") // outbound(こちらから渡す/貸す/約束) / inbound(相手から)
  title      String // 暗号化: 何を (品物・内容・約束の中身)
  value      Int? // 金額/価値の目安 (任意)
  status     String    @default("open") // open(約束/進行中) / done(完了) / returned(返礼/返済済) / canceled
  dueAt      DateTime? @map("due_at") // 期日・返済/返礼の期限
  occurredAt DateTime  @map("occurred_at")
  notes      String? // 暗号化
  prevHash   String?   @map("prev_hash") // 直前レコードのハッシュ (改ざん検知チェーン)
  hash       String? // このレコードの不変中核のハッシュ
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([ownerUid, status])
  @@index([contactId])
  @@index([ownerUid, createdAt])
  @@map("exchanges")
}

/// 統合ハブ: 他プロダクト (cares/vm/zentrack/lms) のレコードへの相互参照。
/// 知り合い/リストを bonds の contacts に集約し、各製品の元レコードへ辿れるようにする。
model ContactExternalRef {
  id         String   @id @default(uuid())
  ownerUid   String   @default("owner") @map("owner_uid")
  contactId  String   @map("contact_id")
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  product    String // cares / vm / zentrack / lms
  externalId String   @map("external_id")
  kind       String   @default("person") // patient / investor / dd_subject / transcript_person / person
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([ownerUid, product, externalId])
  @@index([contactId])
  @@map("contact_external_refs")
}

/// 双方向メッセージのスレッド (連絡先ごと・チャネルごと)。
/// outreach / share 応答 / メール往復を1つの基盤に束ねる (integration-architecture.md §3.2)。
model MessageThread {
  id        String   @id @default(uuid())
  ownerUid  String   @default("owner") @map("owner_uid")
  contactId String   @map("contact_id")
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  channel   String   @default("email") // email / share / line
  subject   String?
  lastAt    DateTime @default(now()) @map("last_at")
  createdAt DateTime @default(now()) @map("created_at")

  messages Message[]

  @@index([ownerUid, contactId])
  @@map("message_threads")
}

model Message {
  id         String        @id @default(uuid())
  threadId   String        @map("thread_id")
  thread     MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  direction  String // outbound / inbound
  body       String // 暗号化
  status     String        @default("sent") // draft / sent / delivered / received / failed
  externalId String?       @map("external_id") // プロバイダのメッセージ ID
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([threadId, createdAt])
  @@map("messages")
}

/// オーナーが差し出せる資源のカタログ (時間・知恵・モノ)。旧 gift の item を
/// 一人称・非マーケットに進化させたもの。gift の give/lend/teach/do/advise → kind。
model SharedResource {
  id           String   @id @default(uuid())
  ownerUid     String   @default("owner") @map("owner_uid")
  kind         String // time / wisdom / thing
  title        String
  description  String? // 暗号化
  availability String? // 空き時間・在庫などの自由記述 (表示用の軽い情報)
  status       String   @default("active") // active / paused / archived
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  shares ResourceShare[]

  @@index([ownerUid, status])
  @@map("shared_resources")
}

/// シェアの成立記録。offer=差し出す / request=頼む / inbound=相手から。
/// 相手は非ユーザーなので公開トークン (share_token) 経由で応答を受ける = 双方向。
/// 応答・確定は contact_interactions に還流する (収集→検証の循環)。
model ResourceShare {
  id           String    @id @default(uuid())
  ownerUid     String    @default("owner") @map("owner_uid")
  contactId    String    @map("contact_id")
  contact      Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  resourceId   String?   @map("resource_id")
  resource     SharedResource? @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  kind         String // time / wisdom / thing
  direction    String    @default("offer") // offer / request / inbound
  title        String
  message      String? // 暗号化 (相手へのひとこと)
  status       String    @default("proposed") // proposed / sent / accepted / declined / fulfilled / cancelled
  shareToken   String?   @unique @map("share_token") // 公開応答用マジックリンクのトークン
  responseNote String?   @map("response_note") // 暗号化 (相手の返答)
  respondedAt  DateTime? @map("responded_at")
  fulfilledAt  DateTime? @map("fulfilled_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([ownerUid, contactId, status])
  @@map("resource_shares")
}

/// 接触記録。距離スコアの入力であり、発信結果の還流先。
model ContactInteraction {
  id         String   @id @default(uuid())
  contactId  String   @map("contact_id")
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type       String // meeting / call / message / letter / email / gift_sent / gift_received
  quality    Int? // 1–5
  occurredAt DateTime @map("occurred_at")
  notes      String? // 暗号化
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([contactId, occurredAt])
  @@map("contact_interactions")
}

/// 贈り物の記録 (誕生日・年賀状・慶事)。
model ContactGift {
  id        String   @id @default(uuid())
  contactId String   @map("contact_id")
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  occasion  String // birthday / new_year / celebration / thanks / other
  direction String   @default("outbound") // outbound / inbound
  item      String
  amount    Int?
  notes     String? // 暗号化
  givenAt   DateTime @map("given_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([contactId])
  @@map("contact_gifts")
}

/// 連絡先グループ (家族・同窓・仕事チームなど)。
model ContactGroup {
  id        String   @id @default(uuid())
  ownerUid  String   @default("owner") @map("owner_uid")
  groupName String   @map("group_name")
  type      String   @default("other")
  members   Json? // contact id の配列
  createdAt DateTime @default(now()) @map("created_at")

  @@index([ownerUid])
  @@map("contact_groups")
}

/// カレンダー連携 (busy スロットのキャッシュ)。contact_id が null なら自分の busy。
/// フェーズ5 で Google/Outlook のライブ OAuth 同期を載せる (今は手動/API 登録)。
model CalendarLink {
  id        String   @id @default(uuid())
  ownerUid  String   @default("owner") @map("owner_uid")
  contactId String?  @map("contact_id") // "self" = 自分 (NULL は複合ユニークで重複可になるため番兵値を使う)
  provider  String   @default("manual") // manual / ics / google / outlook
  busySlots Json     @map("busy_slots") // [{start, end}] ISO 文字列
  icsUrl    String?  @map("ics_url") // 暗号化。ICS 購読 URL (秘密のアドレス = 実質トークン)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([ownerUid, contactId])
  @@map("calendar_links")
}

/// 発信 (outreach)。既定フローは draft → approved → sent (CLAUDE.md 自律性の段階)。
/// body / candidates は文面 (PII) のためアプリ層暗号化。
model OutreachMessage {
  id                String    @id @default(uuid())
  ownerUid          String    @default("owner") @map("owner_uid")
  contactId         String    @map("contact_id")
  channel           String    @default("email") // email / gift / nengajo / press / offer / meeting_invite
  direction         String    @default("outbound")
  purpose           String    @default("keepup") // keepup / birthday / thanks / meeting / contribution / repair
  subject           String?
  body              String? // 暗号化 (承認された本文)
  candidates        String? // 暗号化 (生成した文面候補の JSON 文字列)
  status            String    @default("draft") // draft / approved / sent / failed / replied
  errorDetail       String?   @map("error_detail")
  providerMessageId String?   @map("provider_message_id")
  scheduledAt       DateTime? @map("scheduled_at")
  sentAt            DateTime? @map("sent_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([ownerUid, contactId, status])
  @@map("outreach_messages")
}

/// Google 連携 (Calendar / Gmail / Drive の読み取り専用)。人物データの受動収集に使う。
/// refresh token は実質「本人の Google データへの合鍵」なのでアプリ層暗号化。
model GoogleConnection {
  id           String    @id @default(uuid())
  ownerUid     String    @unique @map("owner_uid")
  email        String? // 接続した Google アカウント (表示用)
  refreshToken String    @map("refresh_token") // 暗号化
  scopes       String?
  syncCalendarIds Json?  @map("sync_calendar_ids") // 取り込む/表示するカレンダー id の配列 (未設定=primary のみ)
  lastSyncAt   DateTime? @map("last_sync_at")
  lastSyncNote String?   @map("last_sync_note") // 直近同期の件数など (表示用)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("google_connections")
}

/// デバイス連携 (Oura / Withings 等) — 共通取り込み基盤。トークンは暗号化。
/// 使うのは cares 等の各プロダクトだが、格納は bonds (接続ハブ) に一本化する。
model DeviceConnection {
  id             String    @id @default(uuid())
  ownerUid       String    @map("owner_uid")
  provider       String // oura | withings
  refreshToken   String    @map("refresh_token") // 暗号化
  accessToken    String?   @map("access_token") // 暗号化 (短命。無ければ refresh で取り直す)
  externalUserId String?   @map("external_user_id") // Withings の userid 等
  scopes         String?
  lastSyncAt     DateTime? @map("last_sync_at")
  lastSyncNote   String?   @map("last_sync_note")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@unique([ownerUid, provider])
  @@map("device_connections")
}

/// デバイス由来の日次健康データ (要配慮情報のため中身は暗号化 JSON)。
/// provider×kind×day で冪等 upsert。読み手は cares / LMS (API 経由)。
model HealthMetric {
  id        String   @id @default(uuid())
  ownerUid  String   @map("owner_uid")
  provider  String // oura | withings
  kind      String // sleep | readiness | activity など
  day       DateTime @db.Date
  payload   String // 暗号化 JSON
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([ownerUid, provider, kind, day])
  @@index([ownerUid, day])
  @@map("health_metrics")
}

/// 監査ログ (フェーズ5)。書き込み系 API の who/what/when を記録する。
model AuditLog {
  id        String   @id @default(uuid())
  actor     String // 認証経路: firebase:<uid> / owner:<email> / breakglass
  method    String
  path      String
  status    Int
  detail    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("audit_logs")
}

/// 提携先 (成長アウトリーチ) の候補と状態。cares ADR-0022 の移植。管理者 (オーナー) 専用。
/// 発見 → 下書き → 承認送信 → 返信 → 提携 (公開ディレクトリ掲載) のファネルを持つ。
model PartnerTarget {
  id              String    @id @default(uuid())
  kind            String    @default("other") // site / sns / association / community / service / corp / other
  name            String
  url             String?
  handle          String? // SNS handle 等
  contactEmail    String?   @map("contact_email") // 暗号化 (要配慮の連絡先)
  source          String? // 発見元 (検索/紹介/イベント等)
  status          String    @default("candidate") // candidate / queued / contacted / replied / partner / declined / suppressed
  notes           String? // 管理者の精査メモ
  isPublic        Boolean   @default(false) @map("is_public") // 提携先ディレクトリ (/partners) 掲載
  blurb           String? // 公開ディレクトリ用の一言紹介
  displayOrder    Int       @default(0) @map("display_order")
  lastContactedAt DateTime? @map("last_contacted_at")
  state           String    @default("active") // active / archived (ソフト削除)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  messages PartnerMessage[]

  @@index([status, kind])
  @@index([isPublic, displayOrder])
  @@map("partner_targets")
}

/// 提携先との連絡履歴。本文はアプリ層暗号化。既定フローは draft → approved → sent (承認制)。
/// 自動送信は PARTNER_AUTO_SEND=1 の明示許可時のみ (CLAUDE.md 自律性の段階)。
model PartnerMessage {
  id                String        @id @default(uuid())
  targetId          String        @map("target_id")
  target            PartnerTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)
  direction         String        @default("outbound") // outbound / inbound
  channel           String        @default("email")
  subject           String?
  body              String // 暗号化
  status            String        @default("draft") // draft / approved / sent / failed / received
  providerMessageId String?       @map("provider_message_id")
  errorDetail       String?       @map("error_detail")
  sentAt            DateTime?     @map("sent_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@index([targetId, createdAt])
  @@index([status])
  @@map("partner_messages")
}

/// 空き時間の設定 (timeshare の FreeTimeSetting の概念を新規実装)。
/// 曜日ごとの受け付け時間窓・予定の前後の余白 (移動/準備)・これ未満は出さない最低時間。
/// 秘密情報ではない (時間の好みのみ) ため暗号化しない。
model AvailabilitySetting {
  id            String   @id @default(uuid())
  ownerUid      String   @unique @map("owner_uid")
  days          Json // {mon..sun: {enabled, startHour, startMinute, endHour, endMinute}}
  bufferMinutes Int      @default(0) @map("buffer_minutes")
  minMinutes    Int      @default(30) @map("min_minutes")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("availability_settings")
}

// カレンダーをドラッグしてなぞった「この日はここが空いている」の明示枠 (timeshare の
// free_times の踏襲)。なぞった日はこの枠がそのまま空きになり、なぞっていない日は
// 曜日別の受付時間 (AvailabilitySetting) が使われる。予定の中身は持たない (枠だけ)。
model AvailabilitySlot {
  id       String   @id @default(uuid())
  ownerUid String   @default("owner") @map("owner_uid")
  startAt  DateTime @map("start_at")
  endAt    DateTime @map("end_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([ownerUid, startAt])
  @@map("availability_slots")
}

// 提案の見送り (✖️)。連絡帳の各提案 (行事・督促・距離感・はじめの一手など) でユーザーが
// 「今回は要らない」と消したものを記録し、再表示しない。key に日付や年を含む提案は、
// 次の機会 (別の key) になれば自然にまた出る。記録そのものは何も消さない。
model SuggestionDismissal {
  id        String   @id @default(uuid())
  ownerUid  String   @default("owner") @map("owner_uid")
  kind      String // gift_occasion / exchange_reminder / distance / drift / goal_nudge / recent_meeting / daily_question / first_move など
  key       String // 提案を特定する鍵 (contactId や日付・行事名の組)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([ownerUid, kind, key])
  @@map("suggestion_dismissals")
}

/// 日程の共有リンク (timeshare の FreeTimeShare の概念を新規実装)。
/// 推測不能な share_key の URL を相手 (アカウント不要の第三者) に送り、相手はこちらの
/// 空き枠から候補を選んで提案し、ユーザーが承認して確定する (下書き→承認→実行の原則)。
/// ページに出すのは空き枠と名乗りだけ (予定の中身は出さない)。任意でパスワード・有効期限。
model ScheduleShare {
  id           String    @id @default(uuid())
  ownerUid     String    @default("owner") @map("owner_uid")
  contactId    String?   @map("contact_id") // 紐づける相手 (承認時に接触記録へ還流)
  shareKey     String    @unique @map("share_key")
  title        String    @default("")
  displayName  String    @default("") @map("display_name") // ページに出す名乗り (ユーザーが選ぶ公開情報)
  method       String    @default("meeting") // meeting / online / phone
  note         String    @default("") // 相手へのひとこと (公開・サニタイズ済み)
  periodStart  DateTime  @map("period_start")
  periodEnd    DateTime  @map("period_end")
  slotMinutes  Int       @default(60) @map("slot_minutes")
  passwordHash String?   @map("password_hash") // scrypt。null = パスワードなし
  expiresAt    DateTime? @map("expires_at") // null = 期限なし (既定は期間終了 + 1 か月)
  state        String    @default("active") // active / archived (ソフト削除)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  proposals    ScheduleShareProposal[]
  participants ScheduleShareParticipant[]

  @@index([ownerUid, state])
  @@map("schedule_shares")
}

/// 共有リンクの参加者 (timeshare の FreeTimeShareUser の概念を新規実装)。
/// 同じ URL に入った相手が自分の予定表 (ICS) を重ねると、ページは全員の共通の
/// 空き時間だけを表示する。名乗りと ICS URL (秘密のアドレス) は暗号化。
/// busy の中身は枠 (時刻) のみで予定の中身は保存しない。
model ScheduleShareParticipant {
  id             String        @id @default(uuid())
  shareId        String        @map("share_id")
  share          ScheduleShare @relation(fields: [shareId], references: [id], onDelete: Cascade)
  participantKey String        @unique @map("participant_key") // 本人が自分の分を更新するための鍵
  name           String // 暗号化 (第三者の名乗り)
  icsUrl         String?       @map("ics_url") // 暗号化 (予定表の購読 URL = 実質トークン)
  busySlots      Json          @map("busy_slots") // [{start, end}] 時刻のみ
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@index([shareId])
  @@map("schedule_share_participants")
}

/// 共有リンクへの相手からの候補提案。相手 (第三者) の名乗り・連絡先・メッセージは PII = 暗号化。
model ScheduleShareProposal {
  id           String        @id @default(uuid())
  shareId      String        @map("share_id")
  share        ScheduleShare @relation(fields: [shareId], references: [id], onDelete: Cascade)
  guestName    String        @map("guest_name") // 暗号化
  guestContact String?       @map("guest_contact") // 暗号化
  message      String?      // 暗号化
  candidates   Json // [{start, end}] 時刻のみ (PII ではない)
  status       String        @default("proposed") // proposed / accepted / declined
  decidedSlot  Json?         @map("decided_slot") // 承認した枠 {start, end}
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@index([shareId, status])
  @@map("schedule_share_proposals")
}

/// 時間の出品 (timeshare スポットコンサルの概念を新規実装)。
/// 空き枠を相談などのメニューとして公開し、予約 + Stripe 決済 (BMP-LP 方式 = REST 直・
/// 鍵は Secret Manager のみ) で受ける。price_jpy 0 は無料 (決済なしで確定)。
model TimeOffer {
  id          String   @id @default(uuid())
  ownerUid    String   @default("owner") @map("owner_uid")
  offerKey    String   @unique @map("offer_key")
  title       String
  description String   @default("")
  displayName String   @default("") @map("display_name")
  method      String   @default("online") // meeting / online / phone
  minutes     Int      @default(60)
  priceJpy    Int      @default(0) @map("price_jpy")
  active      Boolean  @default(true)
  listed      Boolean  @default(false) // 公開掲示板 (/market) に載せる。既定は非公開 (鍵付き URL のみ)
  availabilityWindow String? @map("availability_window") // JSON: この出品を受ける曜日・時間帯 (null = 空き全体)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  bookings TimeBooking[]

  @@index([ownerUid, active])
  @@map("time_offers")
}

/// 時間の予約。ゲスト (第三者) の名乗り・連絡先・メッセージは PII = 暗号化。
/// 有料は pending_payment → (Stripe 支払い確認) → confirmed。無料は即 confirmed。
model TimeBooking {
  id              String    @id @default(uuid())
  offerId         String    @map("offer_id")
  offer           TimeOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  ownerUid        String    @map("owner_uid")
  guestName       String    @map("guest_name") // 暗号化
  guestContact    String?   @map("guest_contact") // 暗号化
  message         String?  // 暗号化
  slot            Json // {start, end}
  status          String    @default("pending_payment") // pending_payment / confirmed / canceled / expired
  amountJpy       Int       @map("amount_jpy")
  stripeSessionId String?   @unique @map("stripe_session_id")
  paidAt          DateTime? @map("paid_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([ownerUid, status])
  @@index([offerId, status])
  @@map("time_bookings")
}

/// あなたへの提案 (優先度に基づく自動ケアの受け箱)。毎時 sweep が優先リスト上位の方に
/// ついて「次の一手」を提案として置き、ユーザーが実行/済み/見送りを選ぶ (最終判断はユーザー)。
/// 本文は相手の状況に触れうるため暗号化。
model CareSuggestion {
  id        String   @id @default(uuid())
  ownerUid  String   @map("owner_uid")
  contactId String   @map("contact_id")
  kind      String // import_talk / set_goal / reach_out / meet / capture_note
  body      String? // 暗号化 (提案のひとこと)
  status    String   @default("proposed") // proposed / done / dismissed
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([ownerUid, status])
  @@index([contactId, kind, status])
  @@map("care_suggestions")
}

// あなたが提供できること (申し出カタログ)。gift の item.action (give/lend/teach/do/advise)
// の概念を bonds のミッション「貢献のためのアクション」に絞って新規実装。マーケットプレイス・
// ポイント経済・FB 認証は移植しない。相手のニーズ (悩み・課題・夢) と突き合わせて
// 「この申し出が役立ちそうな方」を提示する土台。title/description は暗号化 (資源情報の保護)。
model Offering {
  id          String   @id @default(uuid())
  ownerUid    String   @default("owner") @map("owner_uid")
  kind        String // give(譲る) / lend(貸す) / teach(教える) / help(手伝う) / advise(相談にのる) / other
  title       String // 暗号化: 何ができるか (例: 英語を教えられる)
  description String? // 暗号化: 補足
  category    String? // 分類 (自由記述の一語)
  situations  String? // JSON 文字列: 状況タグ
  logistics   String? // JSON 文字列: 受け渡し方法 (対面/データ/貸与など)
  maxDistance Int? @map("max_distance") // 距離ゲート (1〜5)。設定時はこの距離以内の方だけに提案
  active      Boolean  @default(true)
  published   Boolean  @default(false) // 公開掲示板 (/market) に載せる。既定は非公開 (既存連絡先へのマッチングのみ)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  interests OfferingInterest[]

  @@index([ownerUid, active])
  @@map("offerings")
}

// 公開掲示板 (/market) の申し出に対する、アカウント不要の訪問者からの問い合わせ。
// 下書き→承認で新しい連絡先として取り込む (収集の入口)。名乗り・連絡先・本文は暗号化。
model OfferingInterest {
  id           String   @id @default(uuid())
  offeringId   String   @map("offering_id")
  offering     Offering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  ownerUid     String   @map("owner_uid")
  guestName    String   @map("guest_name") // 暗号化
  guestContact String?  @map("guest_contact") // 暗号化
  message      String? // 暗号化
  status       String   @default("new") // new / approved / dismissed
  contactId    String?  @map("contact_id") // 承認で作った連絡先
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([ownerUid, status])
  @@map("offering_interests")
}

/// 公人 (dd_subjects) と人脈 (contacts) の任意リンク (DESIGN-HANDOVER §2 の将来項目)。
model PersonLink {
  id        String   @id @default(uuid())
  ownerUid  String   @default("owner") @map("owner_uid")
  contactId String   @map("contact_id")
  subjectId String   @map("subject_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([ownerUid, contactId, subjectId])
  @@index([ownerUid, contactId])
  @@map("person_links")
}

/// 一斉配信 (メールのお便り)。1 通の文面を、選んだ相手にまとめて送る。
/// 文面は暗号化。送信は少しずつ (日次上限) + 配信停止 + 送信者表示を必ず付ける。
model EmailCampaign {
  id         String                   @id @default(uuid())
  ownerUid   String                   @map("owner_uid")
  subject    String // 暗号化
  body       String // 暗号化 (テンプレ。{{お名前}}/{{会社}} を差し込む)
  segment    Json // 宛先セグメント条件 (距離・最終接触・会社・全員 など)
  fromName   String?                  @map("from_name")
  status     String                   @default("draft") // draft / approved / sending / sent / canceled
  dailyLimit Int                      @default(200) @map("daily_limit")
  total      Int                      @default(0)
  sent       Int                      @default(0)
  failed     Int                      @default(0)
  skipped    Int                      @default(0)
  createdAt  DateTime                 @default(now()) @map("created_at")
  approvedAt DateTime?                @map("approved_at")
  updatedAt  DateTime                 @updatedAt @map("updated_at")
  recipients EmailCampaignRecipient[]

  @@index([ownerUid, status])
  @@map("email_campaigns")
}

model EmailCampaignRecipient {
  id         String        @id @default(uuid())
  campaignId String        @map("campaign_id")
  campaign   EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId  String        @map("contact_id")
  status     String        @default("queued") // queued / sent / failed / skipped
  error      String?
  sentAt     DateTime?     @map("sent_at")
  createdAt  DateTime      @default(now()) @map("created_at")

  @@unique([campaignId, contactId])
  @@index([campaignId, status])
  @@map("email_campaign_recipients")
}

/// 公人評価の下ごしらえ (連絡先 → 人物DD)。自動で特定できた方は resolved で評価へ、
/// 特定不能・候補多数は pending で保留し、ユーザーが候補から選ぶ (最終判断はユーザー)。
model DdSuggestion {
  id         String   @id @default(uuid())
  ownerUid   String   @map("owner_uid")
  contactId  String   @map("contact_id")
  candidates String? // 暗号化: identify の候補 [{name, description}] の JSON
  status     String   @default("pending") // pending / resolved / dismissed / none (候補なし)
  subjectId  String?  @map("subject_id") // resolved のとき、作成した dd_subjects.id
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([ownerUid, contactId])
  @@index([ownerUid, status])
  @@map("dd_suggestions")
}

/// 録音メモ (Plaud のメール添付テキスト)。1 通 1 行・冪等 (gmailMessageId 一意)。
/// 本文抜粋・要旨・タスクと課題 (JSON 文字列) は中身そのもの = 暗号化。
model VoiceMemo {
  id             String    @id @default(uuid())
  ownerUid       String    @map("owner_uid")
  gmailMessageId String    @map("gmail_message_id") // Gmail 由来は実 id、ZenTrack 由来は "zentrack:<hash>"
  source         String    @default("gmail") // gmail / zentrack
  contentHash    String?   @map("content_hash") // 正規化した本文の sha256。経路が違っても同じ文字起こしを一度だけにする
  subject        String?
  receivedAt     DateTime? @map("received_at")
  content        String // 暗号化 (添付テキストの抜粋)
  summary        String? // 暗号化 (要旨の散文)
  tasks          String? // 暗号化 (JSON: [{text, kind: task|issue, done}])
  status         String    @default("new") // new / done / dismissed
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@unique([ownerUid, gmailMessageId])
  @@unique([ownerUid, contentHash])
  @@index([ownerUid, status])
  @@map("voice_memos")
}

/// 配信停止リスト。復号せず突き合わせられるよう鍵つきハッシュで持つ (ownerUid 単位)。
model EmailSuppression {
  id        String   @id @default(uuid())
  ownerUid  String   @map("owner_uid")
  emailHash String   @map("email_hash")
  reason    String   @default("unsubscribe")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([ownerUid, emailHash])
  @@map("email_suppressions")
}

// 実行待ち (受け入れた提案の在庫)。ホームの提案 (サービスの提供・時間調整・メール連絡・
// 贈り物など) をユーザーが受け入れたら、ここに貯めて実行しやすい形で並べる。
// 出力履歴 (something new の構造化・AI-LEVERAGE-DESIGN.md)。
// 生成のたびに出した提案の要旨を残し、次の生成へ「既出リスト」として渡して重複を防ぐ。
model OutputHistory {
  id        String   @id @default(uuid())
  ownerUid  String   @default("owner") @map("owner_uid")
  contactId String?  @map("contact_id")
  kind      String // 生成の種類 (playbook / gift_suggest など)
  summary   String // 暗号化 (出した提案の要旨)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([ownerUid, contactId, kind, createdAt])
  @@map("output_history")
}

model ActionItem {
  id         String    @id @default(uuid())
  ownerUid   String    @default("owner") @map("owner_uid")
  contactId  String?   @map("contact_id")
  kind       String    @default("other") // email / meet / gift / offer / other
  title      String // 暗号化 (何をするか)
  note       String? // 暗号化 (補足)
  sourceKind String?   @map("source_kind") // 由来 (today/growth/offering/gift_occasion/manual など)
  sourceKey  String?   @map("source_key") // 由来キー (同じ提案の二重受け入れ防止)
  status     String    @default("pending") // pending / done / dismissed
  doneAt     DateTime? @map("done_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@unique([ownerUid, sourceKind, sourceKey])
  @@index([ownerUid, status])
  @@map("action_items")
}
