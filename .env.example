# bonds ローカル開発用 env サンプル。`cp .env.example .env` して埋める。
# DB フィールド暗号化マスター鍵 (AES-256-GCM, 64 hex = 32 byte)。
#   必ず自分で生成した値を入れる: openssl rand -hex 32
#   (このサンプルの具体値は使わない。公知の鍵だと全 PII が復号できてしまう)
DATA_ENCRYPTION_KEY=<openssl rand -hex 32 で生成した64桁の16進>
# CORS 許可 Origin (カンマ区切り)。
ALLOWED_ORIGINS=http://localhost:3000
# 人物DD の書き込み・実行を守る管理トークン。必ず自分で生成する: openssl rand -hex 32
ADMIN_BREAKGLASS_TOKEN=<openssl rand -hex 32 で生成した値>
# オーナー本人のメール (このメールでログインすると owner スコープ + 管理者になる)
OWNER_EMAIL=
# AI キー (サーバ側のみ。未設定なら評価実行は 503)
ANTHROPIC_API_KEY=
# Google ログイン (cares と同じ Firebase プロジェクトの値を貼る。未設定でも開発は動く)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# API 側の Firebase 検証 (サービスアカウント JSON 1 行。cares と同一プロジェクトのもの)
FIREBASE_SERVICE_ACCOUNT_JSON=
