# bonds ローカル開発用 env サンプル。`cp .env.example .env` して埋める。
# DB フィールド暗号化マスター鍵 (AES-256-GCM, 64 hex = 32 byte)。
#   生成: openssl rand -hex 32
DATA_ENCRYPTION_KEY=4e107972818fcee63f3c91de6ed6f7143edab3f4169bcfe9abc95034c5e1996f
# CORS 許可 Origin (カンマ区切り)。
ALLOWED_ORIGINS=http://localhost:3000
# 人物DD の書き込み・実行を守る管理トークン (openssl rand -hex 32)
ADMIN_BREAKGLASS_TOKEN=dev-admin-token
# AI キー (サーバ側のみ。未設定なら評価実行は 503)
ANTHROPIC_API_KEY=
